{
	"name": "obsidian-maproom",
	"version": "0.1.0",
	"description": "Semantic search for Obsidian vaults powered by Maproom",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"test": "vitest run",
		"lint": "eslint .",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"maproom",
		"semantic-search",
		"embeddings"
	],
	"author": "Manifold Logic",
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "^9.30.0",
		"@types/node": "^22.0.0",
		"esbuild": "^0.25.0",
		"eslint-plugin-obsidianmd": "^0.1.9",
		"globals": "^14.0.0",
		"jiti": "^2.6.0",
		"tslib": "^2.4.0",
		"typescript": "^5.8.0",
		"typescript-eslint": "^8.35.0",
		"vitest": "^4.1.4"
	},
	"dependencies": {
		"obsidian": "latest"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}